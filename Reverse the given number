import java.util.*;
public class javaBasics {
    public static void main(String[] args) {
        int n = 230206;
        while (n > 0) {
            int lastDigit = n % 10;
            int rev = 0;
            rev = (rev*10) + lastDigit;           
            n = n / 10;
        }
        System.out.println(rev);
    }
}
